# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then copy the token it gives you
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# The chat/channel ID where the digest should be posted
# For a private group: use a negative number like -1001234567890
# For your own account: send /start to @userinfobot to get your ID
TELEGRAM_CHAT_ID=123456789

# ── Security ──────────────────────────────────────────────────────────────────
# A random secret used to protect the /api/digest endpoint
# Generate one with: openssl rand -hex 32
CRON_SECRET=your-very-secret-random-string-here

# ── Vercel KV (Upstash Redis) ─────────────────────────────────────────────────
# These are injected automatically when you add a KV store in the Vercel dashboard.
# You can also copy them from the Vercel project → Storage → KV → .env.local tab.
KV_REST_API_URL=https://your-kv-store.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-rest-api-token

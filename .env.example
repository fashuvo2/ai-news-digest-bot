# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then copy the token it gives you
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# The chat/channel ID where the digest should be posted
# For a private group: use a negative number like -1001234567890
# For your own account: send /start to @userinfobot to get your ID
TELEGRAM_CHAT_ID=123456789

# ── Security ──────────────────────────────────────────────────────────────────
# A random secret used to protect the /api/digest endpoint
# Generate one with: openssl rand -hex 32
CRON_SECRET=your-very-secret-random-string-here

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# These are injected automatically when you add an Upstash Redis integration
# from the Vercel Marketplace: vercel.com/marketplace?category=storage&search=redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
